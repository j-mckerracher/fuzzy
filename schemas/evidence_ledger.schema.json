{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Evidence Ledger",
  "type": "object",
  "required": ["schema_version", "evidence"],
  "properties": {
    "schema_version": { "const": "fuzzy.evidence.v1" },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "claim", "source_type", "source", "confidence"],
        "properties": {
          "id": { "type": "string", "pattern": "^E-[0-9]{3}$" },
          "claim": { "type": "string" },
          "source_type": { "type": "string" },
          "source": { "type": "string" },
          "confidence": { "type": "string" }
        }
      }
    }
  }
}
